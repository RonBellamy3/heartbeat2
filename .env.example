# Copy this file to .env and fill in real values before running in production.

DATABASE_URL="postgresql://user:password@localhost:5432/heartbeat"

# Auth.js (NextAuth) — generate a secret with `openssl rand -base64 32`
AUTH_SECRET=""
AUTH_TRUST_HOST=true
AUTH_URL="http://localhost:3000"

# Google OAuth — from https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: <AUTH_URL>/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# MusicBrainz requires a descriptive User-Agent identifying the app (no API key needed)
MUSICBRAINZ_USER_AGENT="Heartbeat/0.1 (https://your-site.example; you@example.com)"

# Phase 3 (Releases / Tours) — not required for Phase 1
SPOTIFY_CLIENT_ID=""
SPOTIFY_CLIENT_SECRET=""
TICKETMASTER_API_KEY=""
BANDSINTOWN_APP_ID=""
